# Copy to .env in this folder (server/.env) and fill in your values.
# Atlas: https://www.mongodb.com/docs/atlas/getting-started/

NODE_ENV=development
PORT=5000

# Paste your Atlas URI from Database -> Connect -> Drivers (replace USER, PASSWORD, host, cluster)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/skill-exchange?retryWrites=true&w=majority&appName=Cluster0

# Long random string used to sign JWTs (change in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
